{
  "name": "cignus-monorepo",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/desktop"
  ],
  "scripts": {
    "mobile": "npm run start --workspace apps/mobile",
    "mobile:web": "npm run web --workspace apps/mobile",
    "mobile:lint": "npm run lint --workspace apps/mobile",
    "mobile:build:web": "npm run build:web --workspace apps/mobile",
    "desktop:start": "npm run electron:start --workspace apps/desktop",
    "desktop:build:win": "npm run build:desktop:win --workspace apps/desktop",
    "desktop:build:mac": "npm run build:desktop:mac --workspace apps/desktop"
  },
  "devDependencies": {
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}

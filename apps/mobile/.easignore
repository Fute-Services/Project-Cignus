# Mirror of .gitignore (EAS uses this file INSTEAD of .gitignore when present)
node_modules/
.expo/
dist/
web-build/
expo-env.d.ts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*
.DS_Store
*.pem
.env*.local
*.tsbuildinfo
example
/ios
/android

# EAS-only: keep the lockfile out of the build archive so EAS runs
# `npm install` instead of `npm ci`. npm 11 on Windows prunes
# Linux-only optional deps (@emnapi/*) from the lockfile, which makes
# `npm ci` fail on EAS's Linux workers with "not in sync" every time
# someone touches npm on a Windows machine.
package-lock.json
.git

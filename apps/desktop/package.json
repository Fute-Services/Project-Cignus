{
  "name": "@cignus/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "scripts": {
    "electron:start": "electron electron/main.js",
    "build:mobile-web": "npm run build:web --workspace apps/mobile",
    "build:desktop:win": "npm run build:mobile-web && electron-builder --win --x64",
    "build:desktop:mac": "npm run build:mobile-web && electron-builder --mac --x64 --arm64"
  }
}
